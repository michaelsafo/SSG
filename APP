    if (tab === currentTab) return;
    setTransitioning(true);
    setContentVisible(false);
    setTimeout(() => {
      setCurrentTab(tab);
      setTransitioning(false);
      setContentVisible(true);
    }, 420);
  };

  // Contact shortcut from any screen
  const handleNav = (dest) => {
    if (dest === "contact") navigate("more");
    else if (dest === "about") navigate("more");
    else if (dest === "services") navigate("more");
    else if (dest === "brands") navigate("more");
    else navigate(dest);
  };

  const screens = {
    home: <HomeScreen onNav={handleNav} />,
    safo: <SAFOScreen onNav={handleNav} />,
    roster: <RosterScreen onNav={handleNav} />,
    news: <NewsScreen />,
