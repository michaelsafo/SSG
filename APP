  const [form, setForm] = useState({ name: "", sport: "", school: "", followers: "", position: "", conference: "" });
  const [score, setScore] = useState(0);
  const [animScore, setAnimScore] = useState(0);
  const [matchedBrands, setMatchedBrands] = useState([]);

  const sports = ["Basketball", "Football", "Soccer", "Track & Field", "Baseball", "Softball", "Lacrosse", "Tennis", "Swimming", "Volleyball"];

  const runAnalysis = () => {
    if (!form.name || !form.sport) return;
    setStep(1);
    setTimeout(() => {
      const base = 65;
      const followerBonus = Math.min(20, (parseInt(form.followers) || 0) / 500);
      const sportBonus = ["Basketball", "Football", "Soccer"].includes(form.sport) ? 8 : 4;
      const final = Math.min(99, Math.round(base + followerBonus + sportBonus + Math.random() * 6));
      setScore(final);
      const shuffled = [...BRANDS].sort(() => Math.random() - 0.5).slice(0, 5).map(b => ({ ...b, match: Math.round(60 + Math.random() * 35) })).sort((a, b) => b.match - a.match);
      setMatchedBrands(shuffled);
      setStep(2);
      let current = 0;
      const interval = setInterval(() => {
        current += 2;
        if (current >= final) { setAnimScore(final); clearInterval(interval); }
        else setAnimScore(current);
      }, 20);
    }, 2200);
  };

